### Get All Gigs
GET http://localhost:5000/api/gigs


# ==========================================
# Replace YOUR_GIG_ID with an actual gig _id
# from the Get All Gigs response above.
# Replace YOUR_TOKEN with a fresh login token.
# ==========================================

### Get Single Gig (Public - no token needed)
GET http://localhost:5000/api/gigs/6a3e769baad78ded4c724688


### Update Gig (Owner Client Only)
# ✅ Should return 200 if token belongs to the gig owner
# ❌ Should return 403 if token belongs to a different client
PUT http://localhost:5000/api/gigs/6a3e769baad78ded4c724688
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjZhM2U3NTViYWFkNzhkZWQ0YzcyNDY4MCIsImlhdCI6MTc4MjQ3ODMyNywiZXhwIjoxNzgzMDgzMTI3fQ.MJyI1-BytjP92qDUlQ-lT4E_3cL-8blo4wSWa6uRS0I

{
  "title": "Updated MERN Website Project",
